# ─── El Oráculo de Nueva Eternia · Plantilla de entorno ───────────────────────
# Copia este archivo a `.env` y rellena con valores REALES.
# NUNCA subas `.env` a git (ya está en .gitignore).
#
# Genera secretos fuertes con:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"

# development | production
# En "production" la app ABORTA el arranque si JWT_SECRET u ORACULO_API_KEY
# conservan su valor de ejemplo. docker-compose.prod.yml y
# docker-compose.local-prod.yml ya fijan ENV=production automáticamente.
ENV=development
DEBUG=false

# ─── Seguridad (OBLIGATORIO rotar antes de producción) ────────────────────────
# Clave de firma de JWT. Debe ser larga y aleatoria.
JWT_SECRET=CHANGE-ME-run-the-token_urlsafe-command
JWT_EXPIRE_MINUTES=1440

# Clave server-to-server (scrapers/workers). NUNCA se envía desde el navegador.
ORACULO_API_KEY=CHANGE-ME-run-the-token_urlsafe-command

# Clave de bajo privilegio para la extensión de Chrome de Wallapop (solo
# habilita POST /api/wallapop/import). Configúrala también en el popup de la
# extensión (chrome-extension/popup.html). Si se filtra no da acceso admin.
EXTENSION_API_KEY=CHANGE-ME-run-the-token_urlsafe-command

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Orígenes permitidos, separados por coma. En prod, solo tu dominio.
# Dev: http://localhost:3001,http://127.0.0.1:3001
# Prod: https://oraculo-eternia.duckdns.org
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# ─── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./oraculo.db
# En producción se exige Postgres/Supabase:
SUPABASE_DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Notificaciones (Telegram) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Oráculo de Nueva Eternia <notificaciones@eternia.com>

# ─── Imágenes / Cloudinary ────────────────────────────────────────────────────
IMAGE_CACHE_DIR=data/image_cache
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Scraping ─────────────────────────────────────────────────────────────────
SCRAPERAPI_KEY=

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# El frontend YA NO usa la API key. Deja esto vacío / no lo definas.
# VITE_ORACULO_API_KEY=  # DEPRECADO — no usar
